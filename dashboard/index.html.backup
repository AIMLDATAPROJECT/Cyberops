<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Platform Dashboard</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: #0f172a;
            color: #e2e8f0;
            min-height: 100vh;
        }
        .header {
            background: linear-gradient(135deg, #1e293b 0%, #334155 100%);
            padding: 20px 40px;
            border-bottom: 1px solid #475569;
        }
        .header h1 {
            font-size: 28px;
            background: linear-gradient(90deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .header p { color: #94a3b8; margin-top: 5px; }
        .container { max-width: 1400px; margin: 0 auto; padding: 30px 40px; }
        .agents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .agent-card {
            background: #1e293b;
            border-radius: 12px;
            padding: 20px;
            border: 1px solid #334155;
            transition: all 0.3s ease;
        }
        .agent-card:hover {
            border-color: #60a5fa;
            transform: translateY(-2px);
        }
        .agent-card.offline {
            opacity: 0.6;
            border-color: #ef4444;
        }
        .agent-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 15px;
        }
        .agent-icon {
            width: 48px;
            height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
        }
        .agent-ai { background: #dbeafe; }
        .agent-data { background: #dcfce7; }
        .agent-devops { background: #fef3c7; }
        .agent-netmon { background: #fce7f3; }
        .agent-security { background: #fee2e2; }
        .agent-title { font-size: 18px; font-weight: 600; }
        .status-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 500;
        }
        .status-online {
            background: #dcfce7;
            color: #166534;
        }
        .status-offline {
            background: #fee2e2;
            color: #991b1b;
        }
        .test-section {
            background: #1e293b;
            border-radius: 12px;
            padding: 25px;
            border: 1px solid #334155;
        }
        .test-section h2 {
            margin-bottom: 20px;
            color: #60a5fa;
        }
        .form-group {
            margin-bottom: 15px;
        }
        label {
            display: block;
            margin-bottom: 5px;
            color: #94a3b8;
            font-size: 14px;
        }
        select, textarea, input {
            width: 100%;
            padding: 12px;
            background: #0f172a;
            border: 1px solid #334155;
            border-radius: 8px;
            color: #e2e8f0;
            font-size: 14px;
        }
        select:focus, textarea:focus, input:focus {
            outline: none;
            border-color: #60a5fa;
        }
        textarea { min-height: 100px; resize: vertical; }
        .btn {
            background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 100%);
            color: white;
            border: none;
            padding: 12px 30px;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
            font-weight: 500;
            transition: all 0.3s ease;
        }
        .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(59, 130, 246, 0.3);
        }
        .result-box {
            margin-top: 20px;
            padding: 15px;
            background: #0f172a;
            border-radius: 8px;
            border-left: 3px solid #60a5fa;
            max-height: 400px;
            overflow-y: auto;
        }
        .result-box pre {
            white-space: pre-wrap;
            word-wrap: break-word;
            font-family: 'Monaco', 'Menlo', monospace;
            font-size: 13px;
            color: #e2e8f0;
            line-height: 1.5;
        }
        .result-box .key { color: #60a5fa; }
        .result-box .string { color: #a78bfa; }
        .result-box .number { color: #fbbf24; }
        .result-box .boolean { color: #f472b6; }
        .links {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            margin-bottom: 30px;
        }
        .link-card {
            background: #1e293b;
            padding: 15px 25px;
            border-radius: 8px;
            border: 1px solid #334155;
            text-decoration: none;
            color: #94a3b8;
            transition: all 0.3s ease;
        }
        .link-card:hover {
            border-color: #60a5fa;
            color: #60a5fa;
        }
        .loading {
            display: none;
            text-align: center;
            padding: 20px;
            color: #60a5fa;
        }
    </style>
</head>
<body>
    <div class="header">
        <h1>AI Platform Dashboard</h1>
        <p>Central control panel for all AI agents</p>
    </div>

    <div class="container">
        <div class="links">
            <a href="http://localhost:8000/docs" target="_blank" class="link-card">📚 API Docs</a>
            <a href="http://localhost:3000" target="_blank" class="link-card">📊 Grafana</a>
            <a href="http://localhost:9090" target="_blank" class="link-card">📈 Prometheus</a>
            <a href="http://localhost:9001" target="_blank" class="link-card">🗄️ MinIO</a>
            <a href="http://localhost:8200" target="_blank" class="link-card">🔐 Vault</a>
            <a href="http://localhost:5678" target="_blank" class="link-card">⚡ n8n Workflows</a>
        </div>

        <div class="agents-grid" id="agentsGrid">
            <!-- Agents will be loaded here -->
        </div>

        <div class="test-section">
            <h2>🚀 Test Agents</h2>
            <div class="form-group">
                <label>Select Agent</label>
                <select id="agentSelect">
                    <option value="ai">🤖 AI Agent - Text generation & analysis</option>
                    <option value="data">📊 Data Agent - Query & transform data</option>
                    <option value="netmon">🌐 NetMon Agent - Network monitoring</option>
                    <option value="security">🔒 Security Agent - Scans & encryption</option>
                    <option value="devops">⚙️ DevOps Agent - Docker/K8s commands</option>
                </select>
            </div>
            <div class="form-group">
                <label>Action</label>
                <select id="actionSelect">
                    <option value="generate">generate (AI)</option>
                </select>
            </div>
            <div class="form-group">
                <label>Parameters (JSON)</label>
                <textarea id="paramsInput">{"prompt": "Hello, how are you?", "model": "llama2"}</textarea>
            </div>
            <button class="btn" onclick="executeTask()">Execute Task</button>
            <div class="loading" id="loading">⏳ Processing...</div>
            <div class="result-box" id="resultBox" style="display: none;">
                <pre id="result"></pre>
            </div>
        </div>

        <!-- Multi-Agent Communication Section -->
        <div class="test-section">
            <h2>💬 Multi-Agent Conversation</h2>
            
            <!-- Session Management -->
            <div class="form-group">
                <label>Session ID (optional)</label>
                <input type="text" id="sessionId" placeholder="Enter session ID or leave blank for broadcast" style="width: 100%; padding: 10px; background: #0f172a; border: 1px solid #334155; border-radius: 6px; color: #e2e8f0;">
            </div>
            
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <button class="btn" onclick="createSession()" style="flex: 1;">Create New Session</button>
                <button class="btn" onclick="loadSessionHistory()" style="flex: 1;">Load History</button>
            </div>

            <!-- Agent Message Composer -->
            <div class="form-group">
                <label>From Agent (Sender)</label>
                <select id="senderAgent">
                    <option value="ai">🤖 AI Agent</option>
                    <option value="data">📊 Data Agent</option>
                    <option value="netmon">🌐 NetMon Agent</option>
                    <option value="security">🔒 Security Agent</option>
                    <option value="devops">⚙️ DevOps Agent</option>
                </select>
            </div>

            <div class="form-group">
                <label>To Agent (Recipient)</label>
                <select id="recipientAgent">
                    <option value="broadcast">📢 Broadcast (All Agents)</option>
                    <option value="ai">🤖 AI Agent</option>
                    <option value="data">📊 Data Agent</option>
                    <option value="netmon">🌐 NetMon Agent</option>
                    <option value="security">🔒 Security Agent</option>
                    <option value="devops">⚙️ DevOps Agent</option>
                </select>
            </div>

            <div class="form-group">
                <label>Message Type</label>
                <select id="messageType">
                    <option value="request">📨 Request (Needs Response)</option>
                    <option value="broadcast">📢 Broadcast</option>
                    <option value="context_share">📤 Share Context</option>
                </select>
            </div>

            <div class="form-group">
                <label>Message Content (JSON)</label>
                <textarea id="messageContent" style="min-height: 100px;">{&quot;action&quot;: &quot;analyze&quot;, &quot;params&quot;: {&quot;text&quot;: &quot;Hello agents!&quot;}}</textarea>
            </div>

            <button class="btn" onclick="sendAgentMessage()">Send Message</button>
            <button class="btn" onclick="delegateTask()" style="margin-left: 10px; background: linear-gradient(135deg, #10b981 0%, #059669 100%);">Delegate Task</button>

            <!-- Conversation History -->
            <div class="result-box" id="conversationBox" style="display: none; margin-top: 20px;">
                <h3 style="margin-top: 0; color: #60a5fa;">💬 Conversation History</h3>
                <div id="conversationHistory" style="max-height: 300px; overflow-y: auto;"></div>
            </div>
        </div>

        <!-- Agent Inboxes -->
        <div class="test-section">
            <h2>📥 Agent Inboxes</h2>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <select id="inboxAgent" style="flex: 1;">
                    <option value="ai">🤖 AI Agent</option>
                    <option value="data">📊 Data Agent</option>
                    <option value="netmon">🌐 NetMon Agent</option>
                    <option value="security">🔒 Security Agent</option>
                    <option value="devops">⚙️ DevOps Agent</option>
                </select>
                <button class="btn" onclick="loadInbox()" style="flex: 1;">Refresh Inbox</button>
                <button class="btn" onclick="clearInbox()" style="flex: 1; background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);">Clear</button>
            </div>
            <div class="result-box" id="inboxBox" style="display: none;">
                <div id="inboxContent"></div>
            </div>
        </div>

        <!-- Shared Context -->
        <div class="test-section">
            <h2>🗂️ Shared Context</h2>
            <div style="display: flex; gap: 10px; margin-bottom: 15px;">
                <input type="text" id="contextKey" placeholder="Context key" style="flex: 1; padding: 10px; background: #0f172a; border: 1px solid #334155; border-radius: 6px; color: #e2e8f0;">
                <button class="btn" onclick="getContext()" style="flex: 1;">Get Context</button>
                <button class="btn" onclick="setContext()" style="flex: 1;">Set Context</button>
            </div>
            <div class="form-group">
                <label>Context Value (JSON)</label>
                <textarea id="contextValue" style="min-height: 80px;">{&quot;data&quot;: &quot;shared data here&quot;}</textarea>
            </div>
            <div class="result-box" id="contextBox" style="display: none;">
                <pre id="contextResult"></pre>
            </div>
        </div>
    </div>

    <script>
        const agentActions = {
            ai: ['generate', 'analyze', 'embed', 'chat'],
            data: ['query', 'transform', 'ingest', 'upload'],
            netmon: ['ping', 'bandwidth', 'scan', 'monitor'],
            security: ['scan', 'secret', 'encrypt', 'policy'],
            devops: ['command', 'docker', 'k8s', 'terraform']
        };

        const actionParams = {
            'generate': '{"prompt": "Hello, how are you?", "model": "llama2"}',
            'analyze': '{"text": "Sample text to analyze", "analysis_type": "sentiment"}',
            'embed': '{"texts": ["Hello world", "AI platform"], "model": "llama2"}',
            'chat': '{"messages": [{"role": "user", "content": "Hello"}], "model": "llama2"}',
            'query': '{"dataset_id": "test", "query_type": "filter"}',
            'ping': '{"target": "google.com", "count": 4}',
            'scan': '{"target_type": "config", "target_path": "debug=true"}',
            'command': '{"command": "docker ps"}'
        };

        document.getElementById('agentSelect').addEventListener('change', updateActions);
        document.getElementById('actionSelect').addEventListener('change', updateParams);

        function updateActions() {
            const agent = document.getElementById('agentSelect').value;
            const actions = agentActions[agent] || ['generate'];
            const select = document.getElementById('actionSelect');
            select.innerHTML = actions.map(a => `<option value="${a}">${a}</option>`).join('');
            updateParams();
        }

        function updateParams() {
            const action = document.getElementById('actionSelect').value;
            const defaultParams = actionParams[action] || '{}';
            document.getElementById('paramsInput').value = defaultParams;
        }

        async function loadAgents() {
            try {
                const response = await fetch('http://localhost:8000/agents');
                const agents = await response.json();
                
                const icons = {
                    ai: '🤖',
                    data: '📊',
                    devops: '⚙️',
                    netmon: '🌐',
                    security: '🔒'
                };

                const names = {
                    ai: 'AI Agent',
                    data: 'Data Agent',
                    devops: 'DevOps Agent',
                    netmon: 'NetMon Agent',
                    security: 'Security Agent'
                };

                const grid = document.getElementById('agentsGrid');
                grid.innerHTML = agents.map(agent => `
                    <div class="agent-card ${agent.status === 'offline' ? 'offline' : ''}">
                        <div class="agent-header">
                            <div class="agent-icon agent-${agent.agent_type}">
                                ${icons[agent.agent_type] || '🤖'}
                            </div>
                            <div>
                                <div class="agent-title">${names[agent.agent_type] || agent.agent_type}</div>
                                <span class="status-badge ${agent.status === 'online' ? 'status-online' : 'status-offline'}">
                                    ${agent.status === 'online' ? '🟢' : '🔴'} ${agent.status}
                                </span>
                            </div>
                        </div>
                        <div style="color: #94a3b8; font-size: 13px;">
                            Last check: ${new Date(agent.last_check).toLocaleTimeString()}
                        </div>
                    </div>
                `).join('');
            } catch (error) {
                console.error('Failed to load agents:', error);
            }
        }

        async function executeTask() {
            const agent = document.getElementById('agentSelect').value;
            const action = document.getElementById('actionSelect').value;
            const params = document.getElementById('paramsInput').value;
            
            document.getElementById('loading').style.display = 'block';
            document.getElementById('resultBox').style.display = 'none';
            
            try {
                const response = await fetch(`http://localhost:8000/execute/${agent}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        action: action,
                        params: JSON.parse(params)
                    })
                });
                
                const result = await response.json();
                const formatted = JSON.stringify(result, null, 2);
                const highlighted = formatted.replace(
                    /"([^"]+)":/g, '<span class="key">"$1"</span>:'
                ).replace(
                    /: "([^"]+)"/g, ': <span class="string">"$1"</span>'
                ).replace(
                    /: (\d+)/g, ': <span class="number">$1</span>'
                ).replace(
                    /: (true|false)/g, ': <span class="boolean">$1</span>'
                );
                document.getElementById('result').innerHTML = highlighted;
                document.getElementById('resultBox').style.display = 'block';
            } catch (error) {
                document.getElementById('result').textContent = 'Error: ' + error.message;
                document.getElementById('resultBox').style.display = 'block';
            } finally {
                document.getElementById('loading').style.display = 'none';
            }
        }

        // ============ MULTI-AGENT COMMUNICATION FUNCTIONS ============

        async function createSession() {
            const sender = document.getElementById('senderAgent').value;
            const recipient = document.getElementById('recipientAgent').value;
            const participants = recipient === 'broadcast' 
                ? ['ai', 'data', 'netmon', 'security', 'devops']
                : [sender, recipient];
            
            try {
                const response = await fetch('http://localhost:8000/communicate/session/create', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        participants: participants,
                        initial_context: { created_by: sender }
                    })
                });
                
                const result = await response.json();
                if (result.session) {
                    document.getElementById('sessionId').value = result.session.session_id;
                    alert('Session created: ' + result.session.session_id);
                }
            } catch (error) {
                alert('Error creating session: ' + error.message);
            }
        }

        async function loadSessionHistory() {
            const sessionId = document.getElementById('sessionId').value;
            if (!sessionId) {
                alert('Please enter a session ID');
                return;
            }
            
            try {
                const response = await fetch(`http://localhost:8000/communicate/session/${sessionId}/history`);
                const result = await response.json();
                
                const historyDiv = document.getElementById('conversationHistory');
                const box = document.getElementById('conversationBox');
                
                if (result.messages && result.messages.length > 0) {
                    historyDiv.innerHTML = result.messages.map(msg => `
                        <div style="margin-bottom: 15px; padding: 10px; background: #0f172a; border-radius: 8px; border-left: 3px solid ${msg.sender === 'ai' ? '#60a5fa' : '#a78bfa'};">
                            <div style="display: flex; justify-content: space-between; color: #94a3b8; font-size: 12px;">
                                <span><strong>${msg.sender}</strong> → ${msg.recipient || 'all'}</span>
                                <span>${new Date(msg.timestamp).toLocaleTimeString()}</span>
                            </div>
                            <div style="margin-top: 8px; color: #e2e8f0;">
                                ${JSON.stringify(msg.content, null, 2)}
                            </div>
                        </div>
                    `).reverse().join('');
                    box.style.display = 'block';
                } else {
                    historyDiv.innerHTML = '<div style="color: #94a3b8;">No messages in this session yet.</div>';
                    box.style.display = 'block';
                }
            } catch (error) {
                alert('Error loading history: ' + error.message);
            }
        }

        async function sendAgentMessage() {
            const sender = document.getElementById('senderAgent').value;
            const recipient = document.getElementById('recipientAgent').value;
            const messageType = document.getElementById('messageType').value;
            const content = document.getElementById('messageContent').value;
            const sessionId = document.getElementById('sessionId').value;
            
            try {
                const parsedContent = JSON.parse(content);
                
                let url = 'http://localhost:8000/communicate/message';
                let body = {
                    sender: sender,
                    recipient: recipient === 'broadcast' ? 'broadcast' : recipient,
                    message_type: messageType,
                    content: parsedContent
                };
                
                // If session ID exists, use session messaging
                if (sessionId) {
                    url = `http://localhost:8000/communicate/session/${sessionId}/message`;
                    body = {
                        sender: sender,
                        content: parsedContent
                    };
                }
                
                const response = await fetch(url, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(body)
                });
                
                const result = await response.json();
                
                if (result.status === 'sent' || result.status === 'broadcasted') {
                    alert('Message sent successfully! ID: ' + result.message_id);
                    // Auto-refresh history if in a session
                    if (sessionId) {
                        loadSessionHistory();
                    }
                } else {
                    alert('Error: ' + JSON.stringify(result));
                }
            } catch (error) {
                alert('Error sending message: ' + error.message);
            }
        }

        async function delegateTask() {
            const sender = document.getElementById('senderAgent').value;
            const recipient = document.getElementById('recipientAgent').value;
            const content = document.getElementById('messageContent').value;
            
            if (recipient === 'broadcast') {
                alert('Cannot delegate to broadcast. Please select a specific agent.');
                return;
            }
            
            try {
                const parsedContent = JSON.parse(content);
                
                // Determine the agent port
                const agentPorts = {
                    'ai': 8001,
                    'data': 8002,
                    'devops': 8003,
                    'netmon': 8004,
                    'security': 8005
                };
                
                // Try direct delegation first
                const response = await fetch(`http://localhost:${agentPorts[sender]}/delegate`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        to: recipient,
                        task: parsedContent
                    })
                });
                
                const result = await response.json();
                
                document.getElementById('result').innerHTML = JSON.stringify(result, null, 2);
                document.getElementById('resultBox').style.display = 'block';
                
            } catch (error) {
                alert('Error delegating task: ' + error.message);
            }
        }

        async function loadInbox() {
            const agent = document.getElementById('inboxAgent').value;
            const agentPorts = {
                'ai': 8001,
                'data': 8002,
                'devops': 8003,
                'netmon': 8004,
                'security': 8005
            };
            
            try {
                const response = await fetch(`http://localhost:${agentPorts[agent]}/message/inbox`);
                const result = await response.json();
                
                const inboxDiv = document.getElementById('inboxContent');
                const box = document.getElementById('inboxBox');
                
                if (result.messages && result.messages.length > 0) {
                    inboxDiv.innerHTML = result.messages.map(msg => `
                        <div style="margin-bottom: 12px; padding: 12px; background: #0f172a; border-radius: 8px; border-left: 3px solid #fbbf24;">
                            <div style="display: flex; justify-content: space-between; color: #94a3b8; font-size: 12px; margin-bottom: 8px;">
                                <span><strong>From:</strong> ${msg.sender}</span>
                                <span>${new Date(msg.timestamp).toLocaleTimeString()}</span>
                            </div>
                            <div style="color: #e2e8f0; font-size: 13px;">
                                <strong>Type:</strong> ${msg.message_type}
                            </div>
                            <div style="margin-top: 8px; padding: 8px; background: #1e293b; border-radius: 4px; font-size: 12px; color: #94a3b8;">
                                ${JSON.stringify(msg.content, null, 2)}
                            </div>
                        </div>
                    `).reverse().join('');
                } else {
                    inboxDiv.innerHTML = '<div style="color: #94a3b8; text-align: center; padding: 20px;">📭 Inbox is empty</div>';
                }
                
                box.style.display = 'block';
            } catch (error) {
                alert('Error loading inbox: ' + error.message);
            }
        }

        async function clearInbox() {
            const agent = document.getElementById('inboxAgent').value;
            const agentPorts = {
                'ai': 8001,
                'data': 8002,
                'devops': 8003,
                'netmon': 8004,
                'security': 8005
            };
            
            try {
                await fetch(`http://localhost:${agentPorts[agent]}/message/inbox`, {
                    method: 'DELETE'
                });
                
                document.getElementById('inboxContent').innerHTML = '<div style="color: #94a3b8; text-align: center; padding: 20px;">📭 Inbox cleared</div>';
            } catch (error) {
                alert('Error clearing inbox: ' + error.message);
            }
        }

        async function getContext() {
            const key = document.getElementById('contextKey').value;
            if (!key) {
                alert('Please enter a context key');
                return;
            }
            
            try {
                const response = await fetch(`http://localhost:8000/communicate/shared-context/${key}`);
                const result = await response.json();
                
                const resultBox = document.getElementById('contextBox');
                const resultPre = document.getElementById('contextResult');
                
                if (result) {
                    resultPre.innerHTML = JSON.stringify(result, null, 2);
                } else {
                    resultPre.innerHTML = 'Context not found';
                }
                
                resultBox.style.display = 'block';
            } catch (error) {
                alert('Error getting context: ' + error.message);
            }
        }

        async function setContext() {
            const key = document.getElementById('contextKey').value;
            const value = document.getElementById('contextValue').value;
            
            if (!key) {
                alert('Please enter a context key');
                return;
            }
            
            try {
                const parsedValue = JSON.parse(value);
                
                const response = await fetch(`http://localhost:8000/communicate/shared-context/${key}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ value: parsedValue, ttl: 600 })
                });
                
                const result = await response.json();
                
                if (result.status === 'stored') {
                    alert('Context stored successfully!');
                } else {
                    alert('Error: ' + JSON.stringify(result));
                }
            } catch (error) {
                alert('Error setting context: ' + error.message);
            }
        }

        loadAgents();
        setInterval(loadAgents, 5000);
        updateActions();
    </script>
</body>
</html>
