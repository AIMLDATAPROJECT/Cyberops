{
  "name": "🔒 Security Monitor & Response",
  "nodes": [
    {
      "id": "webhook",
      "name": "Security Task Webhook",
      "type": "n8n-nodes-base.webhook",
      "position": [250, 300],
      "webhookId": "security-tasks",
      "parameters": {
        "httpMethod": "POST",
        "path": "security-tasks",
        "responseMode": "responseNode"
      }
    },
    {
      "id": "switch",
      "name": "Security Task",
      "type": "n8n-nodes-base.switch",
      "position": [450, 300],
      "parameters": {
        "rules": {
          "rules": [
            {
              "value": "vuln_scan",
              "output": 0
            },
            {
              "value": "config_scan",
              "output": 1
            },
            {
              "value": "policy_check",
              "output": 2
            },
            {
              "value": "audit",
              "output": 3
            }
          ]
        },
        "dataType": "string",
        "value1": "={{ $json.action }}"
      }
    },
    {
      "id": "vuln_scan",
      "name": "Vulnerability Scan",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 150],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/security",
        "body": {
          "action": "vuln_scan",
          "params": "={{ JSON.stringify($json.params || {}) }}"
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "config_scan",
      "name": "Config Security Scan",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 250],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/security",
        "body": {
          "action": "config_scan",
          "params": "={{ JSON.stringify($json.params || {}) }}"
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "policy_check",
      "name": "Policy Compliance",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 350],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/security",
        "body": {
          "action": "policy_check",
          "params": "={{ JSON.stringify($json.params || {}) }}"
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "audit",
      "name": "Security Audit",
      "type": "n8n-nodes-base.httpRequest",
      "position": [650, 450],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/security",
        "body": {
          "action": "audit",
          "params": "={{ JSON.stringify($json.params || {}) }}"
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "check_critical",
      "name": "Critical Issues?",
      "type": "n8n-nodes-base.if",
      "position": [850, 300],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "={{ $json.result?.vulnerabilities?.some(v => v.severity === 'critical') || $json.result?.risk_score > 7 || $json.result?.violations?.length > 0 }}",
            "type": "boolean",
            "operator": {
              "type": "boolean",
              "operation": "equals",
              "rightValue": true
            }
          }
        }
      }
    },
    {
      "id": "auto_remediate",
      "name": "Auto-Remediate",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 250],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/security",
        "body": {
          "action": "rotate_secret",
          "params": {
            "secret_name": "compromised_credentials",
            "auto_rotate": true
          }
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "isolate_system",
      "name": "Alert DevOps - Isolate",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 350],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/communicate/message",
        "body": {
          "sender": "security",
          "recipient": "devops",
          "message_type": "request",
          "content": {
            "action": "restart",
            "params": {
              "service": "={{ $json.params.target }}",
              "isolation_mode": true,
              "reason": "Security incident - system isolation"
            }
          }
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "alert_security_team",
      "name": "Alert Security Team",
      "type": "n8n-nodes-base.slack",
      "position": [1250, 300],
      "parameters": {
        "channel": "#security-alerts",
        "text": "🚨 SECURITY INCIDENT DETECTED\n\nSeverity: CRITICAL\nTarget: {{ $json.params.target || 'System' }}\nRisk Score: {{ $json.result.risk_score }}\n\nAuto-remediation: {{ $json.result.auto_remediated ? 'Completed' : 'Failed' }}\nIsolation: {{ $json.result.isolated ? 'Active' : 'Pending' }}\n\nTime: {{ Date.now() }}"
      }
    },
    {
      "id": "store_audit",
      "name": "Store Audit Trail",
      "type": "n8n-nodes-base.httpRequest",
      "position": [850, 500],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/data",
        "body": {
          "action": "ingest",
          "params": {
            "source": "security_audit",
            "format": "json",
            "config": {
              "data": "={{ $json }}",
              "dataset_name": "security_scan_{{ Date.now() }}"
            }
          }
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "ai_analysis",
      "name": "AI Threat Analysis",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1050, 500],
      "parameters": {
        "method": "POST",
        "url": "http://orchestrator:8000/execute/ai",
        "body": {
          "action": "analyze",
          "params": {
            "text": "={{ JSON.stringify($json.result) }}",
            "analysis_type": "security_threat"
          }
        },
        "responseFormat": "json"
      }
    },
    {
      "id": "response",
      "name": "Webhook Response",
      "type": "n8n-nodes-base.webhookResponse",
      "position": [1450, 400],
      "parameters": {
        "statusCode": 200,
        "responseBody": "={{ JSON.stringify({ status: 'security_scan_completed', result: $json }) }}"
      }
    }
  ],
  "connections": {
    "Security Task Webhook": {
      "main": [[{"node": "Security Task", "type": "main", "index": 0}]]
    },
    "Security Task": {
      "main": [
        [{"node": "Vulnerability Scan", "type": "main", "index": 0}],
        [{"node": "Config Security Scan", "type": "main", "index": 0}],
        [{"node": "Policy Compliance", "type": "main", "index": 0}],
        [{"node": "Security Audit", "type": "main", "index": 0}]
      ]
    },
    "Vulnerability Scan": {
      "main": [[{"node": "Critical Issues?", "type": "main", "index": 0}]]
    },
    "Config Security Scan": {
      "main": [[{"node": "Critical Issues?", "type": "main", "index": 0}]]
    },
    "Policy Compliance": {
      "main": [[{"node": "Critical Issues?", "type": "main", "index": 0}]]
    },
    "Security Audit": {
      "main": [[{"node": "Store Audit Trail", "type": "main", "index": 0}]]
    },
    "Critical Issues?": {
      "main": [
        [{"node": "Auto-Remediate", "type": "main", "index": 0}],
        [{"node": "Alert DevOps - Isolate", "type": "main", "index": 0}]
      ]
    },
    "Auto-Remediate": {
      "main": [[{"node": "Alert Security Team", "type": "main", "index": 0}]]
    },
    "Alert DevOps - Isolate": {
      "main": [[{"node": "Alert Security Team", "type": "main", "index": 0}]]
    },
    "Alert Security Team": {
      "main": [[{"node": "Webhook Response", "type": "main", "index": 0}]]
    },
    "Store Audit Trail": {
      "main": [[{"node": "AI Threat Analysis", "type": "main", "index": 0}]]
    },
    "AI Threat Analysis": {
      "main": [[{"node": "Webhook Response", "type": "main", "index": 0}]]
    }
  },
  "settings": {
    "executionOrder": "v1",
    "saveExecutionProgress": true
  },
  "tags": ["security", "monitoring", "auto-remediation"]
}
